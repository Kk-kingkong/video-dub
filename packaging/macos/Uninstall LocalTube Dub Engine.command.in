#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "这会停止并移除 LocalTube Dub Engine、开机自启和 Chrome Native Host。"
read -r -p "确认卸载？请输入 y：" answer
if [[ "$answer" != "y" && "$answer" != "Y" ]]; then
  echo "已取消。"
  exit 0
fi

"$ROOT_DIR/companion/uninstall_native_host_macos.sh"
echo
read -r -p "卸载完成。按回车键关闭窗口..." _
